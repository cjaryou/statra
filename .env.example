# ─── Apple — App Store Connect API ───────────────────────────────
# Create at: App Store Connect → Users and Access → Integrations → App Store Connect API
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_ID=XXXXXXXXXX
# Path to the downloaded .p8 private key
ASC_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# Optional: leave empty and `statra ping ios` lists your apps + ids
ASC_APP_ID=1234567890
# Vendor number — required for `stats`. App Store Connect → Payments and Financial Reports
ASC_VENDOR_NUMBER=12345678

# ─── Google — Play Console ───────────────────────────────────────
# Create a service account in Google Cloud, grant it access in
# Play Console → Users and permissions, and download the JSON key.
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# Your app's package name, e.g. com.example.app
GOOGLE_PACKAGE_NAME=com.example.app
# GCS bucket where Play exports monthly reports (Play Console → Download reports → Cloud Storage URI)
GOOGLE_REPORTS_BUCKET=pubsite_prod_XXXXXXXXXXXXXXXXXXX
