{
  "name": "statra",
  "version": "0.1.0",
  "description": "One CLI for App Store Connect + Google Play stats — downloads, revenue, crashes, ratings in one place.",
  "type": "module",
  "bin": {
    "statra": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "app-store-connect",
    "google-play",
    "cli",
    "analytics",
    "aso",
    "mobile",
    "stats"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "google-auth-library": "^9.14.0",
    "jose": "^5.9.6",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
